<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AmanKos - Hunian Mahasiswa IPB</title>
    <!-- Menggunakan CDN Tailwind CSS yang stabil -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Menggunakan Lucide Icons dari CDN resmi -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');
        
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        @keyframes bounce-slow {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }
        .animate-bounce-slow {
            animation: bounce-slow 4s ease-in-out infinite;
        }

        /* Style untuk Button Mitra & Filter */
        .partner-btn {
            padding: 0.6rem 1.2rem;
            border-radius: 2rem;
            border: 1px solid #ffffff00;
            background-color: rgb(236, 33, 135);
            color: #ffffff; 
            font-size: 15px;
            font-weight: 600;
            transition: all 0.2s;
            box-shadow: 0 1px 5px rgba(0, 0, 0, 0.351);
        }
        .partner-btn:hover {
            border-color: #fecdd3;
            color: rgb(167, 20, 94);
            transform: translateY(-2px);
        }
        .filter-btn {
            font-size: 10px;
            font-weight: 800;
            padding: 0.5rem 1.2rem;
            border-radius: 9999px;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #64748b;
            white-space: nowrap;
            background: none;
            border: none;
            cursor: pointer;
            flex-shrink: 0;
        }
        .filter-btn.active {
            background-color: white;
            color: #be185d;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }

        /* Efek Kartu Kost Statis yang Kontras */
        .kost-card {
            background-color: white;
            border: 1px solid #cbd5e1;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
            transition: transform 0.3s ease;
        }
        .kost-card:hover {
            transform: translateY(-4px);
            border-color: #ec4899;
        }
    </style>
</head>
<body class="bg-white text-slate-900 antialiased">

    <!-- Navbar -->
    <nav class="max-w-6xl mx-auto px-6 h-16 md:h-20 flex items-center justify-between">
        <div class="flex items-center gap-2">
            <i data-lucide="shield-check" class="text-pink-600 w-6 h-6 md:w-7 md:h-7"></i>
            <span class="font-bold text-base md:text-lg tracking-tighter">AMANKOS</span>
        </div>
        <div class="hidden md:flex items-center gap-8 text-[11px] font-bold uppercase tracking-widest text-slate-600">
            <a href="#" class="text-slate-900 border-b-2 border-pink-500 pb-1">Beranda</a>
            <a href="#" class="hover:text-pink-600 transition">Fasilitas</a>
            <a href="#" class="hover:text-pink-600 transition">Testimoni</a>
        </div>
        <div class="md:hidden">
            <i data-lucide="menu" class="text-slate-900 w-6 h-6"></i>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="px-4 mb-10">
        <div class="max-w-6xl mx-auto bg-[#fff5f6] rounded-[2.5rem] md:rounded-[3.5rem] overflow-hidden relative min-h-[400px] md:min-h-[520px] flex items-center shadow-sm border border-pink-100">
            <!-- Gambar Rumah (Kanan) -->
            <div class="absolute right-[-160px] md:right-0 top-0 w-full md:w-1/2 h-full block">
                <img src="rumah.png" alt="Rumah Estetik" class="w-full h-full object-cover rounded-l-[6rem]">
                <div class="absolute inset-0 bg-gradient-to-r from-[#fff5f6] via-[#fff5f6]/80 to-transparent md:via-[#fff5f6]/20"></div>
            </div>

            <!-- Teks Hero (Kiri) -->
            <div class="relative z-10 px-6 md:px-20 lg:w-3/5 py-12 md:py-20">
                <div class="inline-flex items-center gap-2 bg-white px-4 py-1.5 rounded-full shadow-sm mb-4 md:mb-6 border border-pink-100">
                    <span class="w-2 h-2 bg-pink-600 rounded-full animate-pulse"></span>
                    <p class="text-[9px] md:text-[10px] font-extrabold uppercase tracking-widest text-pink-700">200+ Kamar Kos Tersedia</p>
                </div>
                
                <h1 class="text-3xl md:text-7xl font-light leading-[1.1] mb-6 md:mb-8 text-slate-900 tracking-tight">
                    Temukan <span class="font-bold">Rumah</span> <br />
                    Kedua di <span class="text-pink-600 italic">Dramaga.</span>
                </h1>
                
                <div class="flex flex-wrap gap-4 items-center">
                    <button class="bg-pink-600 text-white px-8 md:px-10 py-3.5 md:py-4.5 rounded-full text-[11px] md:text-[12px] font-bold shadow-xl shadow-pink-200 hover:bg-pink-700 transition flex items-center gap-2 uppercase tracking-widest">
                        Mulai Cari <i data-lucide="arrow-right" class="w-4 h-4 ml-1"></i>
                    </button>
                    <div class="flex items-center gap-3 group cursor-pointer">
                        <button class="w-10 h-10 md:w-12 md:h-12 rounded-full border-2 border-pink-200 flex items-center justify-center text-pink-600 bg-white group-hover:bg-pink-600 group-hover:text-white transition shadow-md">
                            <i data-lucide="play" class="w-4 h-4 fill-current ml-0.5"></i>
                        </button>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-600">Lihat Video</span>
                    </div>
                </div>
            </div>
    </header>

    <!-- Partners Section -->
    <div class="max-w-6xl mx-auto px-6 mb-16 overflow-visible text-center">
        <p class="text-[10px] font-bold text-slate-500 uppercase tracking-[0.3em] mb-6">SUMBER LAINNYA</p>
        <div class="flex flex-wrap justify-center items-center gap-3 md:gap-5">
            <button class="partner-btn">IPB University</button>
            <button onclick="window.open('https://mamikos.com', '_blank')" class="partner-btn">Mamikos.com</button>
        </div>
    </div>

    <!-- Galeri Kost -->
    <section class="max-w-6xl mx-auto px-12 md:px-6 mb-24">
        <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-6">
            <div>
                <h2 class="text-2xl md:text-4xl font-bold text-slate-900 tracking-tight">Populer di IPB</h2>
                <p class="text-[12px] text-slate-600 font-semibold mt-1">Kos pilihan mahasiswa yang paling banyak dicari sekitar kampus.</p>
            </div>
            <div id="filter-container" class="flex gap-2 bg-slate-100 p-1.5 rounded-full overflow-x-auto no-scrollbar w-full md:w-auto border border-slate-200 snap-x snap-mandatory">
                <button onclick="filterKost('Semua')" class="filter-btn active">Semua</button>
                <button onclick="filterKost('Babakan Raya')" class="filter-btn">Babakan Raya</button>
                <button onclick="filterKost('Dramaga Cantik')" class="filter-btn">Dramaga Cantik</button>
                <button onclick="filterKost('Balumbang Jaya')" class="filter-btn">Balumbang Jaya</button>
           
            </div>
        </div>

        <!-- Grid: 2 kolom di mobile, 3 di desktop -->
        <div id="kost-grid" class="grid grid-cols-2 md:grid-cols-3 gap-5 md:gap-12">
            <!-- Data dimuat via JS -->
        </div>
    </section>

    <!-- Footer - Warna Pink Pucat (Soft Pink) untuk kontras akhir halaman -->
    <footer class="py-16 bg-[#fff0f3] border-t border-pink-100">
        <div class="max-w-6xl mx-auto px-6 text-center">
            <div class="flex items-center justify-center gap-2 mb-6">
                <div class="w-10 h-10 bg-white rounded-xl flex items-center justify-center shadow-sm border border-pink-100">
                    <i data-lucide="shield-check" class="text-pink-600 w-6 h-6"></i>
                </div>
                <span class="font-black text-xl tracking-tighter text-slate-900">AMANKOS</span>
            </div>
            <p class="text-[10px] font-bold text-pink-800/60 uppercase tracking-[0.4em] mb-10 text-center">Hunian Aman Mahasiswa Berprestasi</p>
            
            <!-- Link Footer -->
            <div class="flex flex-wrap justify-center gap-x-8 gap-y-4 text-[10px] font-black text-slate-700 uppercase tracking-[0.2em] mb-12">
                <a href="#" class="hover:text-pink-600 transition">Tentang Kami</a>
                <a href="#" class="hover:text-pink-600 transition">Syarat & Ketentuan</a>
                <a href="#" class="hover:text-pink-600 transition">Hubungi Admin</a>
                <a href="#" class="hover:text-pink-600 transition">FAQ</a>
            </div>

            <!-- Copyright & Social -->
            <div class="pt-8 border-t border-pink-200/50 flex flex-col md:flex-row justify-between items-center gap-4">
                <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">© 2024 AMANKOS DRAMAGA. SELURUH HAK CIPTA DILINDUNGI.</p>
                <div class="flex gap-4">
                    <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center text-slate-400 hover:text-pink-600 transition cursor-pointer shadow-sm border border-pink-50">
                        <i data-lucide="instagram" class="w-4 h-4"></i>
                    </div>
                    <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center text-slate-400 hover:text-pink-600 transition cursor-pointer shadow-sm border border-pink-50">
                        <i data-lucide="twitter" class="w-4 h-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script>
        // Data Kost
        const kosts = [
            { id: 1, name: "Wisma Darmaga Cantik", area: "Dramaga Cantik", rating: "cowok", image: "https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&q=80&w=400", price: "1.5jt", type: "Putri" },
            { id: 2, name: "Kos Bara 4 Modern", area: "Babakan Raya", rating: "cowok", image: "https://images.unsplash.com/photo-1513694203232-719a280e022f?auto=format&fit=crop&q=80&w=400", price: "800rb", type: "Putra" },
            { id: 3, name: "Residence Balumbang", area: "Balumbang Jaya", rating: "cewek", image: "https://images.unsplash.com/photo-1595526114035-0d45ed16cfbf?auto=format&fit=crop&q=80&w=400", price: "1.1jt", type: "Campur" },
            { id: 4, name: "Kos Putri Perwira", area: "Perwira", rating: 4.5, image: "https://images.unsplash.com/photo-1554995207-c18c203602cb?auto=format&fit=crop&q=80&w=400", price: "950rb", type: "Putri" },
            { id: 5, name: "Wisma Darmaga Cantik", area: "Dramaga Cantik", rating: 4.9, image: "https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?auto=format&fit=crop&q=80&w=400", price: "1.5jt", type: "Putri" },
            { id: 6, name: "Kos Bara 4 Modern", area: "Babakan Raya", rating: 4.4, image: "https://images.unsplash.com/photo-1513694203232-719a280e022f?auto=format&fit=crop&q=80&w=400", price: "800rb", type: "Putra" },
            { id: 7, name: "Residence Balumbang", area: "Balumbang Jaya", rating: 4.7, image: "https://images.unsplash.com/photo-1595526114035-0d45ed16cfbf?auto=format&fit=crop&q=80&w=400", price: "1.1jt", type: "Campur" },
            { id: 8, name: "Kos Putri Perwira", area: "Perwira", rating: 4.5, image: "https://images.unsplash.com/photo-1554995207-c18c203602cb?auto=format&fit=crop&q=80&w=400", price: "950rb", type: "Putri" },
        ];

        // Fungsi Render Kost
        function renderKosts(filteredData) {
            const grid = document.getElementById('kost-grid');
            if (!grid) return;
            
            grid.innerHTML = '';
            
            filteredData.forEach(kost => {
                const card = `
                    <div onclick='openModal(${JSON.stringify(kost)})' class="kost-card flex flex-col rounded-[2rem] overflow-hidden">
                        <div class="relative h-40 md:h-72 overflow-hidden">
                            <img src="${kost.image}" alt="${kost.name}" class="w-full h-full object-cover">
                            <div class="absolute top-3 right-3 md:top-5 md:right-5 bg-white px-2.5 py-1 md:px-4 md:py-1.5 rounded-full flex items-center gap-1.5 shadow-md border border-slate-100">
                                <i data-lucide="star" class="w-3 h-3 md:w-3.5 md:h-3.5 text-yellow-500 fill-current"></i>
                                <span class="text-[10px] md:text-[12px] font-black text-slate-900">${kost.rating}</span>
                            </div>
                        </div>
                        <div class="p-4 md:p-8 flex flex-col flex-1">
                            <div class="mb-3 md:mb-6">
                                <h3 class="font-black text-slate-900 text-[13px] md:text-[18px] mb-1 truncate text-left">${kost.name}</h3>
                                <button class="flex items-center gap-1.5 text-slate-700 text-[10px] md:text-[12px] font-bold uppercase tracking-wider hover:text-pink-600 transition text-left">
                                    <i data-lucide="map-pin" class="w-3 h-3 md:w-4 md:h-4 text-pink-500"></i>
                                    <span class="truncate">${kost.area}</span>
                                </button>
                            </div>
                            <div class="flex gap-2.5 mb-5 md:mb-7">
                                <div class="flex items-center gap-1.5 text-slate-800 bg-slate-100 px-3 py-1 rounded-lg text-[9px] md:text-[10px] font-black border border-slate-200">
                                    <i data-lucide="wifi" class="w-3 h-3 text-pink-600"></i> WiFi
                                </div>
                                <div class="flex items-center gap-1.5 text-slate-800 bg-slate-100 px-3 py-1 rounded-lg text-[9px] md:text-[10px] font-black border border-slate-200">
                                    <i data-lucide="wind" class="w-3 h-3 text-pink-600"></i> AC
                                </div>
                            </div>
                            <div class="mt-auto pt-4 md:pt-6 border-t-2 border-slate-100 flex items-center justify-between">
                                <div class="text-left">
                                    <p class="text-[8px] md:text-[10px] text-slate-500 font-black uppercase mb-0.5">Mulai Dari</p>
                                    <span class="text-pink-600 font-black text-sm md:text-xl">Rp ${kost.price}</span>
                                </div>
                                <button class="bg-pink-600 text-white w-8 h-8 md:w-12 md:h-12 rounded-xl flex items-center justify-center shadow-lg shadow-pink-100 hover:bg-pink-700 hover:scale-110 active:scale-95 transition">
                                    <i data-lucide="phone" class="w-4 h-4 md:w-5 md:h-5"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                `;
                grid.insertAdjacentHTML('beforeend', card);
            });
            
            if (window.lucide) {
                window.lucide.createIcons();
            }
        }

        // Fungsi Filter
        function filterKost(area) {
            const buttons = document.querySelectorAll('.filter-btn');
            buttons.forEach(btn => {
                if(btn.innerText.toLowerCase() === area.toLowerCase()) {
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                }
            });

            const filtered = area === 'Semua' ? kosts : kosts.filter(k => k.area === area);
            renderKosts(filtered);
        }

        // Inisialisasi
        document.addEventListener('DOMContentLoaded', () => {
            renderKosts(kosts);
            if (window.lucide) {
                window.lucide.createIcons();
            }
        });
        function openModal(kost) {
        document.getElementById('modal').classList.remove('hidden');
        document.getElementById('modal-title').innerText = kost.name;
        document.getElementById('modal-area').innerText = kost.area;
        document.getElementById('modal-price').innerText = "Rp " + kost.price;
        document.getElementById('modal-image').src = kost.image;
        }
        function closeModal() {
        document.getElementById('modal').classList.add('hidden');
        }
    </script>
     <div id="modal" class="fixed inset-0 bg-black/40 backdrop-blur-sm hidden flex items-center justify-center z-50">
            <div class="bg-white w-[90%] max-w-md rounded-2xl p-6 relative">
        
                 <!-- tombol close -->
                 <button onclick="closeModal()" class="absolute top-3 right-3 text-slate-400 hover:text-black">
                 ✕
                 </button>

                 <!-- isi detail -->
                 <img id="modal-image" class="w-full h-40 object-cover rounded-xl mb-4">
                 <h3 id="modal-title" class="text-lg font-bold mb-1"></h3>
                 <p id="modal-area" class="text-sm text-slate-500 mb-2"></p>
                 <p id="modal-price" class="text-pink-600 font-bold text-xl mb-3"></p>

                 <div class="text-sm text-slate-700">
                    <p>Fasilitas:</p>
                    <ul class="list-disc ml-5">
                        <li>WiFi</li>
                        <li>AC</li>
                        <li>Kamar mandi dalam</li>
                    </ul>
                 </div>
            </div>
        </div>
</body>
</html>
